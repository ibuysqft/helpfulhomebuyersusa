# Site
NEXT_PUBLIC_SITE_URL=https://helpfulhomebuyersusa.com
NEXT_PUBLIC_APP_URL=https://helpfulhomebuyersusa.com
NEXT_PUBLIC_PHONE=+17039401159
NEXT_PUBLIC_PHONE_DISPLAY=(703) 940-1159
ADMIN_NOTIFICATION_EMAIL=info@helpfulhomebuyersusa.com
CONTENT_FROM_EMAIL=content@helpfulhomebuyersusa.com
CONTENT_PUBLISH_MODE=draft

# Supabase (create project at https://supabase.com)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Upstash Redis (create at https://upstash.com)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# GoHighLevel (API v2 — no webhook URL needed)
GHL_API_KEY=your-ghl-api-key
GHL_LOCATION_ID=your-ghl-location-id
GHL_WORKFLOW_TRANSACTIONAL_FOLLOWUP_ID=your-website-transactional-followup-workflow-id
GHL_WORKFLOW_MARKETING_NURTURE_ID=your-website-marketing-nurture-workflow-id
GHL_WORKFLOW_REFERRAL_INTAKE_ID=your-referral-intake-workflow-id
GHL_WORKFLOW_MLS_TRANSACTIONAL_ID=your-mls-transactional-workflow-id

# HHB site messaging / A2P registration
# Keep these in HHB only if the site sends approved SMS outside GHL.
TWILIO_PHONE_NUMBER=+17039401159
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_A2P_BRAND_SID=BNxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_A2P_CAMPAIGN_SID=CPxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Live coach bridge for the separate ghl-power-dialer service
# Keep these in the HHB app only. The external power dialer owns Twilio, GHL voice, and OpenAI runtime credentials.
POWER_DIALER_BASE_URL=https://dialer.helpfulhomebuyersusa.com
POWER_DIALER_ADMIN_API_KEY=your-live-coach-admin-api-key
POWER_DIALER_WEBHOOK_SECRET=your-shared-live-coach-webhook-secret
POWER_DIALER_OVERLAY_TOKEN=your-live-coach-overlay-token
RETELL_WEBHOOK_SECRET=your-retell-webhook-secret

# External ghl-power-dialer runtime secrets
# Do not put these in the HHB Vercel app unless that app is also the runtime service.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_CALLER_ID=+17039401159
TWILIO_STATUS_CALLBACK_URL=https://dialer.helpfulhomebuyersusa.com/twilio/status-callback
TWILIO_AMD_CALLBACK_URL=https://dialer.helpfulhomebuyersusa.com/twilio/amd-callback
TWILIO_RECORDING_STATUS_CALLBACK_URL=https://dialer.helpfulhomebuyersusa.com/twilio/recording-status-callback
TWILIO_MEDIA_STREAM_URL=wss://dialer.helpfulhomebuyersusa.com/twilio/media-stream
TWILIO_AGENT_TARGET_TYPE=number
TWILIO_AGENT_TARGET=+17035550123
TWILIO_AI_TWIML_URL=https://dialer.helpfulhomebuyersusa.com/twilio/calls/example/human.xml
TWILIO_MACHINE_ACTION=hangup
TWILIO_WAIT_MESSAGE=Please hold while we connect your specialist.
TWILIO_WORKSPACE_SID=WKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# MLS lane inside the main HHB subaccount
GHL_MLS_LOCATION_ID=your-mls-location-id
GHL_MLS_CASH_WORKFLOW_ID=your-mls-cash-workflow-id
GHL_MLS_CREATIVE_WORKFLOW_ID=your-mls-creative-workflow-id
GHL_MLS_PIPELINE_ID=your-mls-pipeline-id
GHL_MLS_WEBHOOK_SECRET=your-mls-webhook-secret

# Comp puller service (server-only; do not prefix these with NEXT_PUBLIC_)
COMP_PULLER_URL=https://your-comp-puller-service.example.com
COMP_PULLER_SHARED_SECRET=replace-with-a-long-random-shared-secret

# Anthropic (for blog content generation)
ANTHROPIC_API_KEY=sk-ant-...

# Resend (for draft email notifications — https://resend.com)
RESEND_API_KEY=re_...

# Cron secret (generate a random string, add to Vercel env + vercel.json)
CRON_SECRET=your-random-secret-here

# Distressed lead adapters
DEALMACHINE_INTERNAL_SECRET=your-dealmachine-internal-secret
DEALMACHINE_SOURCE_URL=https://your-dealmachine-source-host/sync
DEALMACHINE_SOURCE_SECRET=replace-me
DEALMACHINE_DELETE_SOURCE_URL=https://your-dealmachine-source-host/delete
DEALMACHINE_DELETE_SOURCE_SECRET=replace-me
PROPERTYRADAR_INTERNAL_SECRET=your-propertyradar-internal-secret
PROPERTYRADAR_SOURCE_URL=https://your-worker-host/propertyradar-sync
PROPERTYRADAR_SOURCE_SECRET=replace-me
DISTRESSED_GHL_EXPORT_SECRET=your-distressed-ghl-export-secret
DISTRESSED_GHL_EXPORT_URL=https://helpfulhomebuyersusa.com/api/internal/distressed-ghl-export
DEALMACHINE_DISTRESSED_SYNC_URL=https://helpfulhomebuyersusa.com/api/internal/dealmachine-sync
DEALMACHINE_DISTRESSED_SYNC_SECRET=your-dealmachine-internal-secret
DEALMACHINE_DELETE_URL=https://helpfulhomebuyersusa.com/api/internal/dealmachine-delete
DEALMACHINE_DELETE_SECRET=your-dealmachine-internal-secret
PROPERTYRADAR_PROBATE_SYNC_URL=https://helpfulhomebuyersusa.com/api/internal/propertyradar-sync
PROPERTYRADAR_PROBATE_SYNC_SECRET=your-propertyradar-internal-secret
MARKET_MEDIANS_SOURCE_URL=https://your-worker-host/market-medians
MARKET_MEDIANS_SOURCE_SECRET=replace-me

# Google Search Console via Workload Identity Federation
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GCP_WORKLOAD_IDENTITY_PROVIDER=projects/123456789/locations/global/workloadIdentityPools/vercel/providers/vercel
GSC_SITE_URL=https://helpfulhomebuyersusa.com
# VERCEL_OIDC_TOKEN is injected by Vercel at runtime for cron/serverless execution

# Google PageSpeed (optional — for SEO audit cron)
PAGESPEED_API_KEY=your-key-here
