{
  "version": 1,
  "_comment": "All Playwright selectors for DealSauce. Claude auto-patches this file when scrapers break.",
  "login": {
    "emailInput": "input[type='email']",
    "passwordInput": "input[type='password']",
    "submitButton": "button[type='submit']",
    "successUrlGlob": "**/leads**"
  },
  "leadsPage": {
    "countySelect": "select[name='county'], [data-filter='county']",
    "leadRow": "[data-testid='lead-row'], .lead-row, tr.lead",
    "fields": {
      "mlsNumber": "[data-mls], .mls-number, [class*='mls']",
      "address": "[data-address], .address, [class*='address']",
      "listPrice": "[data-list-price], .list-price, [class*='price']",
      "wholesaleValue": "[data-wholesale], .wholesale, [class*='wholesale']",
      "beds": "[data-beds], .beds",
      "baths": "[data-baths], .baths",
      "sqft": "[data-sqft], .sqft",
      "agentName": "[data-agent-name], .agent-name",
      "agentEmail": "[data-agent-email], .agent-email",
      "agentPhone": "[data-agent-phone], .agent-phone",
      "description": "[data-description], .description"
    }
  },
  "filters": {
    "leadType":               { "action": "check",  "selector": "[data-lead-type='{value}'], input[value='{value}']" },
    "propertyType":           { "action": "check",  "selector": "[data-property-type='{value}'], input[value='{value}']" },
    "amenity":                { "action": "check",  "selector": "[data-amenity='{value}'], input[value='{value}']" },
    "ownerType":              { "action": "select", "selector": "[name='ownerType'], [data-filter='owner-type']" },
    "listingStatus":          { "action": "select", "selector": "[name='listingStatus'], [data-filter='listing-status']" },
    "daysOnMarket":           { "action": "select", "selector": "[name='daysOnMarket'], [data-filter='dom']" },
    "hoa":                    { "action": "select", "selector": "[name='hoa'], [data-filter='hoa']" },
    "loanType":               { "action": "select", "selector": "[name='loanType'], [data-filter='loan-type']" },
    "mortgageFinanceType":    { "action": "select", "selector": "[name='mortgageFinanceType'], [data-filter='mortgage-finance-type']" },
    "lastSaleDate":           { "action": "select", "selector": "[name='lastSaleDate'], [data-filter='last-sale-date']" },
    "minSqft":                { "action": "select", "selector": "[name='minSqft'], [data-filter='min-sqft']" },
    "maxSqft":                { "action": "select", "selector": "[name='maxSqft'], [data-filter='max-sqft']" },
    "minLotSize":             { "action": "select", "selector": "[name='minLotSize'], [data-filter='min-lot-size']" },
    "maxLotSize":             { "action": "select", "selector": "[name='maxLotSize'], [data-filter='max-lot-size']" },
    "minBeds":                { "action": "select", "selector": "[name='minBeds'], [data-filter='min-beds']" },
    "maxBeds":                { "action": "select", "selector": "[name='maxBeds'], [data-filter='max-beds']" },
    "minBaths":               { "action": "select", "selector": "[name='minBaths'], [data-filter='min-baths']" },
    "maxBaths":               { "action": "select", "selector": "[name='maxBaths'], [data-filter='max-baths']" },
    "hasPhotos":              { "action": "check",  "selector": "[name='hasPhotos'], [data-filter='has-photos']" },
    "hasBeforeAfterPhotos":   { "action": "check",  "selector": "[name='hasBeforeAfterPhotos'], [data-filter='has-before-after-photos']" },
    "intrafamilyTransfer":    { "action": "check",  "selector": "[name='intrafamilyTransfer'], [data-filter='intrafamily-transfer']" },
    "minPrice":               { "action": "fill",   "selector": "[name='minPrice'], [data-filter='min-price']" },
    "maxPrice":               { "action": "fill",   "selector": "[name='maxPrice'], [data-filter='max-price']" },
    "minYearBuilt":           { "action": "fill",   "selector": "[name='minYearBuilt'], [data-filter='min-year']" },
    "maxYearBuilt":           { "action": "fill",   "selector": "[name='maxYearBuilt'], [data-filter='max-year']" },
    "propertyKeywords":       { "action": "fill",   "selector": "[name='propertyKeywords'], [data-filter='property-keywords']" },
    "minProfitPotential":     { "action": "fill",   "selector": "[name='minProfitPotential'], [data-filter='min-profit-potential']" },
    "maxProfitPotential":     { "action": "fill",   "selector": "[name='maxProfitPotential'], [data-filter='max-profit-potential']" },
    "minRetailScore":         { "action": "fill",   "selector": "[name='minRetailScore']" },
    "maxRetailScore":         { "action": "fill",   "selector": "[name='maxRetailScore']" },
    "minRentalScore":         { "action": "fill",   "selector": "[name='minRentalScore']" },
    "maxRentalScore":         { "action": "fill",   "selector": "[name='maxRentalScore']" },
    "minWholesaleScore":      { "action": "fill",   "selector": "[name='minWholesaleScore']" },
    "maxWholesaleScore":      { "action": "fill",   "selector": "[name='maxWholesaleScore']" },
    "minMarketValue":         { "action": "fill",   "selector": "[name='minMarketValue'], [data-filter='min-market-value']" },
    "maxMarketValue":         { "action": "fill",   "selector": "[name='maxMarketValue'], [data-filter='max-market-value']" },
    "minRentalEstimate":      { "action": "fill",   "selector": "[name='minRentalEstimate'], [data-filter='min-rental-estimate']" },
    "maxRentalEstimate":      { "action": "fill",   "selector": "[name='maxRentalEstimate'], [data-filter='max-rental-estimate']" },
    "minLtv":                 { "action": "fill",   "selector": "[name='minLtv'], [data-filter='min-ltv']" },
    "maxLtv":                 { "action": "fill",   "selector": "[name='maxLtv'], [data-filter='max-ltv']" },
    "minEquity":              { "action": "fill",   "selector": "[name='minEquity'], [data-filter='min-equity']" },
    "maxEquity":              { "action": "fill",   "selector": "[name='maxEquity'], [data-filter='max-equity']" },
    "minLoanBalance":         { "action": "fill",   "selector": "[name='minLoanBalance'], [data-filter='min-loan-balance']" },
    "maxLoanBalance":         { "action": "fill",   "selector": "[name='maxLoanBalance'], [data-filter='max-loan-balance']" },
    "minInterestRate":        { "action": "fill",   "selector": "[name='minInterestRate'], [data-filter='min-interest-rate']" },
    "maxInterestRate":        { "action": "fill",   "selector": "[name='maxInterestRate'], [data-filter='max-interest-rate']" },
    "minOpenLoans":           { "action": "fill",   "selector": "[name='minOpenLoans'], [data-filter='min-open-loans']" },
    "maxOpenLoans":           { "action": "fill",   "selector": "[name='maxOpenLoans'], [data-filter='max-open-loans']" },
    "minYearsOwned":          { "action": "fill",   "selector": "[name='minYearsOwned'], [data-filter='min-years-owned']" },
    "maxYearsOwned":          { "action": "fill",   "selector": "[name='maxYearsOwned'], [data-filter='max-years-owned']" },
    "minLastSalePrice":       { "action": "fill",   "selector": "[name='minLastSalePrice'], [data-filter='min-last-sale-price']" },
    "maxLastSalePrice":       { "action": "fill",   "selector": "[name='maxLastSalePrice'], [data-filter='max-last-sale-price']" },
    "minPreforeclosureNotices": { "action": "fill", "selector": "[name='minPreforeclosureNotices']" },
    "maxPreforeclosureNotices": { "action": "fill", "selector": "[name='maxPreforeclosureNotices']" }
  }
}
